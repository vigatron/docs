*******************************  Equations  ********************************

********** Mapped Logic **********

FDCPE_DAC0: FDCPE port map (DAC(0),DAC_D(0),GCLK2,'0','0');
DAC_D(0) <= ((ramdat(0) AND clk2 AND flag_dac)
	OR (DAC(0) AND NOT clk2 AND flag_dac));

FDCPE_DAC1: FDCPE port map (DAC(1),DAC_D(1),GCLK2,'0','0');
DAC_D(1) <= ((ramdat(1) AND clk2 AND flag_dac)
	OR (DAC(1) AND NOT clk2 AND flag_dac));

FDCPE_DAC2: FDCPE port map (DAC(2),DAC_D(2),GCLK2,'0','0');
DAC_D(2) <= ((ramdat(2) AND clk2 AND flag_dac)
	OR (DAC(2) AND NOT clk2 AND flag_dac));

FDCPE_DAC3: FDCPE port map (DAC(3),DAC_D(3),GCLK2,'0','0');
DAC_D(3) <= ((ramdat(3) AND clk2 AND flag_dac)
	OR (DAC(3) AND NOT clk2 AND flag_dac));

FDCPE_DAC4: FDCPE port map (DAC(4),DAC_D(4),GCLK2,'0','0');
DAC_D(4) <= ((ramdat(4) AND clk2 AND flag_dac)
	OR (DAC(4) AND NOT clk2 AND flag_dac));

FDCPE_DAC5: FDCPE port map (DAC(5),DAC_D(5),GCLK2,'0','0');
DAC_D(5) <= ((ramdat(5) AND clk2 AND flag_dac)
	OR (DAC(5) AND NOT clk2 AND flag_dac));

FDCPE_DAC6: FDCPE port map (DAC(6),DAC_D(6),GCLK2,'0','0');
DAC_D(6) <= ((ramdat(6) AND clk2 AND flag_dac)
	OR (DAC(6) AND NOT clk2 AND flag_dac));

FDCPE_DAC7: FDCPE port map (DAC(7),DAC_D(7),GCLK2,'0','0');
DAC_D(7) <= ((ramdat(7) AND clk2 AND flag_dac)
	OR (DAC(7) AND NOT clk2 AND flag_dac));

FTCPE_HSYNC: FTCPE port map (HSYNC,HSYNC_T,GCLK2,'0','0');
HSYNC_T <= ((pxlcnt(3) AND pxlcnt(6) AND NOT pxlcnt(7) AND NOT pxlcnt(9) AND 
	NOT pxlcnt(0) AND pxlcnt(2) AND NOT pxlcnt(1) AND NOT pxlcnt(4) AND NOT pxlcnt(5) AND 
	NOT pxlcnt(8) AND NOT HSYNC)
	OR (NOT pxlcnt(3) AND NOT pxlcnt(6) AND NOT pxlcnt(7) AND NOT pxlcnt(9) AND 
	NOT pxlcnt(0) AND NOT pxlcnt(2) AND NOT pxlcnt(1) AND NOT pxlcnt(4) AND NOT pxlcnt(5) AND 
	NOT pxlcnt(8) AND HSYNC));

FTCPE_Mtrien_SRAM_DATA: FTCPE port map (Mtrien_SRAM_DATA,Mtrien_SRAM_DATA_T,GCLK2,'0','0');
Mtrien_SRAM_DATA_T <= ((flag_w AND Mtrien_SRAM_DATA AND NOT clk2)
	OR (NOT Mtrien_SRAM_DATA AND clk2 AND flag_r));

FTCPE_RAM_CE: FTCPE port map (RAM_CE,RAM_CE_T,GCLK2,'0','0',flag_vis);
RAM_CE_T <= ((RAM_CE AND pxlcnt(3) AND NOT pxlcnt(6) AND pxlcnt(7) AND 
	NOT pxlcnt(9) AND NOT pxlcnt(0) AND NOT pxlcnt(2) AND pxlcnt(1) AND NOT pxlcnt(4) AND 
	NOT pxlcnt(5) AND NOT pxlcnt(8) AND flag_up AND clk2)
	OR (RAM_CE AND pxlcnt(3) AND NOT pxlcnt(6) AND pxlcnt(7) AND 
	NOT pxlcnt(9) AND NOT pxlcnt(0) AND NOT pxlcnt(2) AND pxlcnt(1) AND NOT pxlcnt(4) AND 
	NOT pxlcnt(5) AND NOT pxlcnt(8) AND NOT flag_up AND NOT clk2)
	OR (NOT RAM_CE AND NOT pxlcnt(3) AND pxlcnt(6) AND NOT pxlcnt(7) AND 
	pxlcnt(9) AND NOT pxlcnt(0) AND NOT pxlcnt(2) AND pxlcnt(1) AND NOT pxlcnt(4) AND 
	NOT pxlcnt(5) AND NOT pxlcnt(8) AND flag_up AND clk2)
	OR (NOT RAM_CE AND NOT pxlcnt(3) AND pxlcnt(6) AND NOT pxlcnt(7) AND 
	pxlcnt(9) AND NOT pxlcnt(0) AND NOT pxlcnt(2) AND pxlcnt(1) AND NOT pxlcnt(4) AND 
	NOT pxlcnt(5) AND NOT pxlcnt(8) AND NOT flag_up AND NOT clk2));

FDCPE_RAM_RD: FDCPE port map (RAM_RD,RAM_RD_D,GCLK2,'0','0');
RAM_RD_D <= ((RAM_RD AND NOT flag_r)
	OR (NOT clk2 AND flag_r)
	OR (NOT lincnt(0) AND NOT lincnt(2) AND NOT lincnt(5) AND NOT lincnt(1) AND 
	NOT lincnt(3) AND NOT lincnt(4) AND NOT lincnt(6) AND NOT lincnt(7) AND NOT lincnt(8) AND 
	NOT lincnt(9) AND NOT flag_r));

FDCPE_RAM_WR: FDCPE port map (RAM_WR,RAM_WR_D,GCLK2,'0','0');
RAM_WR_D <= ((flag_w AND clk2)
	OR (NOT flag_w AND RAM_WR)
	OR (NOT flag_w AND NOT lincnt(0) AND NOT lincnt(2) AND NOT lincnt(5) AND 
	NOT lincnt(1) AND NOT lincnt(3) AND NOT lincnt(4) AND NOT lincnt(6) AND NOT lincnt(7) AND 
	NOT lincnt(8) AND NOT lincnt(9)));

FDCPE_SRAM_ADDR0: FDCPE port map (SRAM_ADDR(0),SRAM_ADDR_D(0),GCLK2,'0','0');
SRAM_ADDR_D(0) <= ((flag_w AND ramptr(0) AND NOT clk2)
	OR (NOT flag_w AND SRAM_ADDR(0) AND NOT clk2)
	OR (ramptr(0) AND clk2 AND flag_r)
	OR (SRAM_ADDR(0) AND clk2 AND NOT flag_r));

FDCPE_SRAM_ADDR1: FDCPE port map (SRAM_ADDR(1),SRAM_ADDR_D(1),GCLK2,'0','0');
SRAM_ADDR_D(1) <= ((flag_w AND ramptr(1) AND NOT clk2)
	OR (NOT flag_w AND SRAM_ADDR(1) AND NOT clk2)
	OR (ramptr(1) AND clk2 AND flag_r)
	OR (SRAM_ADDR(1) AND clk2 AND NOT flag_r));

FDCPE_SRAM_ADDR2: FDCPE port map (SRAM_ADDR(2),SRAM_ADDR_D(2),GCLK2,'0','0');
SRAM_ADDR_D(2) <= ((flag_w AND ramptr(2) AND NOT clk2)
	OR (NOT flag_w AND SRAM_ADDR(2) AND NOT clk2)
	OR (ramptr(2) AND clk2 AND flag_r)
	OR (SRAM_ADDR(2) AND clk2 AND NOT flag_r));

FDCPE_SRAM_ADDR3: FDCPE port map (SRAM_ADDR(3),SRAM_ADDR_D(3),GCLK2,'0','0');
SRAM_ADDR_D(3) <= ((flag_w AND ramptr(3) AND NOT clk2)
	OR (NOT flag_w AND SRAM_ADDR(3) AND NOT clk2)
	OR (ramptr(3) AND clk2 AND flag_r)
	OR (SRAM_ADDR(3) AND clk2 AND NOT flag_r));

FDCPE_SRAM_ADDR4: FDCPE port map (SRAM_ADDR(4),SRAM_ADDR_D(4),GCLK2,'0','0');
SRAM_ADDR_D(4) <= ((flag_w AND ramptr(4) AND NOT clk2)
	OR (NOT flag_w AND SRAM_ADDR(4) AND NOT clk2)
	OR (ramptr(4) AND clk2 AND flag_r)
	OR (SRAM_ADDR(4) AND clk2 AND NOT flag_r));

FDCPE_SRAM_ADDR5: FDCPE port map (SRAM_ADDR(5),SRAM_ADDR_D(5),GCLK2,'0','0');
SRAM_ADDR_D(5) <= ((flag_w AND ramptr(5) AND NOT clk2)
	OR (NOT flag_w AND SRAM_ADDR(5) AND NOT clk2)
	OR (ramptr(5) AND clk2 AND flag_r)
	OR (SRAM_ADDR(5) AND clk2 AND NOT flag_r));

FDCPE_SRAM_ADDR6: FDCPE port map (SRAM_ADDR(6),SRAM_ADDR_D(6),GCLK2,'0','0');
SRAM_ADDR_D(6) <= ((flag_w AND ramptr(6) AND NOT clk2)
	OR (NOT flag_w AND SRAM_ADDR(6) AND NOT clk2)
	OR (ramptr(6) AND clk2 AND flag_r)
	OR (SRAM_ADDR(6) AND clk2 AND NOT flag_r));

FDCPE_SRAM_ADDR7: FDCPE port map (SRAM_ADDR(7),SRAM_ADDR_D(7),GCLK2,'0','0');
SRAM_ADDR_D(7) <= ((flag_w AND ramptr(7) AND NOT clk2)
	OR (NOT flag_w AND SRAM_ADDR(7) AND NOT clk2)
	OR (ramptr(7) AND clk2 AND flag_r)
	OR (SRAM_ADDR(7) AND clk2 AND NOT flag_r));

FDCPE_SRAM_ADDR8: FDCPE port map (SRAM_ADDR(8),SRAM_ADDR_D(8),GCLK2,'0','0');
SRAM_ADDR_D(8) <= ((flag_w AND ramptr(8) AND NOT clk2)
	OR (NOT flag_w AND SRAM_ADDR(8) AND NOT clk2)
